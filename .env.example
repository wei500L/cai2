ENV=dev
LOG_LEVEL=INFO
LLM_PROVIDER=mock
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-v4-flash
ENABLE_PERSISTENCE=false
EXTRA_CORS_ORIGINS=
HOST=127.0.0.1
PORT=8000
WS_PATH=/ws
REST_PREFIX=/debug/v1
# 前端默认走真实 ws，联调时后端不在线会直接暴露连接失败。
# 兼容开关；设为 true 会强制启用 mock transport。
VITE_ALLOW_MOCK_FALLBACK=false
VITE_WS_URL=ws://localhost:8000/ws
VITE_WS_TOKEN=dev-mock-token
VITE_BACKEND_REST_BASE=http://localhost:8000/debug/v1
VITE_HEARTBEAT_MS=15000
