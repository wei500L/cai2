ENV=prod
LOG_LEVEL=INFO
LLM_PROVIDER=openai
OPENAI_API_KEY=replace-with-production-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1
ENABLE_PERSISTENCE=true
EXTRA_CORS_ORIGINS=https://your-frontend.example.com
HOST=0.0.0.0
PORT=8000
WS_PATH=/ws
REST_PREFIX=/debug/v1

VITE_ALLOW_MOCK_FALLBACK=false
VITE_WS_URL=wss://your-backend.example.com/ws
VITE_WS_TOKEN=
VITE_BACKEND_REST_BASE=https://your-backend.example.com/debug/v1
VITE_HEARTBEAT_MS=15000
VITE_APP_VERSION=0.1.0
